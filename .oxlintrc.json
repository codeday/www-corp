{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "maxWarnings": 10
  },
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-redundant-type-constituents": "off",
    "restrict-template-expressions": "off",
    "no-for-in-array": "off",
    "no-new-array": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "vendor/**",
    "test/snapshots/**",
    "packages/topocons/**"
  ]
}
